# ==============================================================================
# Configurações de API Keys para Modelos (LLMs)
# ==============================================================================
# Preencha a chave correspondente ao modelo que você deseja utilizar no projeto.
# ATENÇÃO: Nunca versione o seu arquivo `.env` com as chaves reais!

# 1. OpenAI (Modelos GPT-3.5, GPT-4, etc.)
OPENAI_API_KEY="sk-SuaChaveOpenAIAqui..."

# 2. Google Gemini (Modelos Gemini Pro, etc.)
GEMINI_API_KEY="AIzaSySuaChaveGeminiAqui..."

# 3. DeepSeek (DeepSeek Coder, DeepSeek Chat, etc.)
DEEPSEEK_API_KEY="sk-SuaChaveDeepSeekAqui..."

# 4. Anthropic (Modelos Claude)
ANTHROPIC_API_KEY="sk-ant-SuaChaveAnthropicAqui..."
